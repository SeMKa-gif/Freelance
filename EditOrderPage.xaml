<Page x:Class="Kyrsovai.EditOrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kyrsovai"
      mc:Ignorable="d" 
      Title="Редактирование заказа" Background="#b5f5d6" Width="1180" Height="Auto" MinHeight="700"
      Loaded="Page_Loaded">

    <Page.Resources>
        <ControlTemplate x:Key="myTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <Style TargetType="Button">
            <Setter Property="Background" Value="LightGreen"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#11f084"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#10b364"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="10" Margin="10" Background="White">
            <Grid>
                <WrapPanel Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
                    <Image Source="/logo.png" Height="45" Width="45" Margin="0,0,10,0">
                        <Image.Clip>
                            <EllipseGeometry Center="22.5,22.5" RadiusX="22.5" RadiusY="22.5"/>
                        </Image.Clip>
                    </Image>
                    <TextBlock Text="Фриланс-биржа NowWork" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Форма редактирования -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="10" Margin="10" Background="White" 
                HorizontalAlignment="Center" VerticalAlignment="Center" Width="650">
            <StackPanel Margin="20">
                <TextBlock Text="Редактирование заказа" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Название" FontSize="16"/>
                <TextBox x:Name="TitleBox" FontSize="16" Margin="0,5,0,10"/>

                <TextBlock Text="Описание" FontSize="16"/>
                <TextBox x:Name="DescriptionBox" FontSize="16" Height="80" TextWrapping="Wrap" Margin="0,5,0,10"/>

                <TextBlock Text="Срок выполнения" FontSize="16"/>
                <DatePicker x:Name="DeadlineBox" FontSize="16" Margin="0,5,0,10"/>

                <TextBlock Text="Цена" FontSize="16"/>
                <TextBox x:Name="PriceBox" FontSize="16" Margin="0,5,0,10"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Сохранить" Click="SaveButton_Click" Width="120"/>
                    <Button Content="Отмена" Click="CancelButton_Click" Width="120" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Подвал -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="10" Margin="10" Background="#f8f8f8">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" 
                           Text="© 2026 Фриланс-биржа. Все права защищены. | Контакты: info@freelance.ru | +7 (999) 123-45-67"/>
                <WrapPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
                               TextDecorations="Underline" Text="Пользовательское соглашение" Margin="5"/>
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
                               TextDecorations="Underline" Text="Политика конфиденциальности" Margin="5"/>
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
                               TextDecorations="Underline" Text="Помощь и поддержка" Margin="5"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
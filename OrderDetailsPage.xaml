<Page x:Class="Kyrsovai.OrderDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kyrsovai"
      mc:Ignorable="d" 
      Title="Детали заказа" Background="#b5f5d6" Width="1180" Height="Auto" MinHeight="700">

    <Page.Resources>
        <ControlTemplate x:Key="myTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <Style TargetType="Button">
            <Setter Property="Background" Value="LightGreen"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#11f084"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#10b364"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="10" Margin="10" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="/logo.png" Height="45" Width="45" Margin="0,0,10,0">
                        <Image.Clip>
                            <EllipseGeometry Center="22.5,22.5" RadiusX="22.5" RadiusY="22.5"/>
                        </Image.Clip>
                    </Image>
                    <TextBlock Text="Фриланс-биржа NowWork" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button x:Name="Iworker1" Template="{StaticResource myTemplate}" Content="Я заказчик" Width="130" Margin="0,0,10,0" Click="Iworker1_Click"/>
                    <Button x:Name="Ifrilance" Background="#10b364" Template="{StaticResource myTemplate}" Content="Я фрилансер" Width="130" Margin="0,0,10,0" Click="Ifrilance_Click"/>
                    <Button x:Name="MyBidsButton" Content="Мои отклики" Template="{StaticResource myTemplate}" Width="140" Margin="0,0,10,0" Click="MyBidsButton_Click"/>
                    <Button x:Name="OrderBidsButton" Content="Отклики на мои заказы" Template="{StaticResource myTemplate}" Width="215" Click="OrderBidsButton_Click"/>
                </WrapPanel>

                <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,5,10,10" VerticalAlignment="Center">
                    <TextBlock x:Name="GuestText" Text="Гость" FontSize="14" VerticalAlignment="Center" 
           MaxWidth="450" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, ElementName=GuestText}" Opacity="0.7" Margin="0,0,10,0"/>
                    <Button x:Name="EnterButton" Content="Войти" Template="{StaticResource myTemplate}" Width="90" Height="35" Click="ButtonVoiti_Click" Margin="0,0,10,0"/>
                    <Button x:Name="ExitButton" Background="#f5b5d0" Content="Выйти" Template="{StaticResource myTemplate}" Width="90" Height="35" Click="ButtonExit_Click" Visibility="Collapsed"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Детали заказа -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="10" Margin="10" Background="White"
        HorizontalAlignment="Center" VerticalAlignment="Top" Width="800">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="30">
                    <Image x:Name="OrderImage" Height="300" Stretch="Uniform" Margin="0,0,0,20"/>
                    <TextBlock x:Name="OrderTitle" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="OrderDescription" FontSize="18" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <TextBlock x:Name="OrderDeadline" FontSize="16" Margin="0,0,0,10" Foreground="Gray"/>
                    <TextBlock x:Name="OrderPrice" FontSize="24" FontWeight="Bold" Foreground="Red" Margin="0,0,0,20"/>
                    <TextBlock x:Name="OrderRating" FontSize="20" Foreground="Gold" Margin="0,0,0,20"/>
                    <TextBlock x:Name="OrderAuthor" FontSize="16" Margin="0,0,0,10" Foreground="Gray" HorizontalAlignment="Left"/>
                    <Button x:Name="RespondButton" Content="Откликнуться" Template="{StaticResource myTemplate}" Width="200" Margin="0,10,0,0" HorizontalAlignment="Center" Click="RespondButton_Click"/>
                    <Button Content="Назад к заказам" Template="{StaticResource myTemplate}" Width="200" Margin="0,0,0,0" HorizontalAlignment="Center" Click="BackButton_Click"/>
                    <Button x:Name="EditButton" Content="Редактировать" Template="{StaticResource myTemplate}" Width="200" Click="EditButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="DeleteButton" Content="Удалить" Template="{StaticResource myTemplate}" Width="200" Click="DeleteButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Подвал -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="10" Margin="10" Background="#f8f8f8">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" 
                           Text="© 2026 Фриланс-биржа. Все права защищены. | Контакты: info@freelance.ru | +7 (999) 123-45-67"/>
                <WrapPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
           TextDecorations="Underline" Text="Пользовательское соглашение" Margin="5"
           Cursor="Hand" MouseLeftButtonDown="Agreement_Click"/>
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
           TextDecorations="Underline" Text="Политика конфиденциальности" Margin="5"
           Cursor="Hand" MouseLeftButtonDown="Privacy_Click"/>
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
           TextDecorations="Underline" Text="Помощь и поддержка" Margin="5"
           Cursor="Hand" MouseLeftButtonDown="Support_Click"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
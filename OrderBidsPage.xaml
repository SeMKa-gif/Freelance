<Page x:Class="Kyrsovai.OrderBidsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kyrsovai"
      mc:Ignorable="d" 
      Title="Отклики на мои заказы" Background="#b5f5d6" Width="1180" Height="Auto" MinHeight="700">

    <Page.Resources>
        <ControlTemplate x:Key="myTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <Style TargetType="Button">
            <Setter Property="Background" Value="LightGreen"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#11f084"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#10b364"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="10" Margin="10" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="/logo.png" Height="45" Width="45" Margin="0,0,10,0">
                        <Image.Clip>
                            <EllipseGeometry Center="22.5,22.5" RadiusX="22.5" RadiusY="22.5"/>
                        </Image.Clip>
                    </Image>
                    <TextBlock Text="Фриланс-биржа NowWork" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button x:Name="Iworker1" Template="{StaticResource myTemplate}" Content="Я заказчик" Width="130" Margin="0,0,10,0" Click="Iworker1_Click"/>
                    <Button x:Name="Ifrilance" Template="{StaticResource myTemplate}" Content="Я фрилансер" Width="130" Margin="0,0,10,0" Click="Ifrilance_Click"/>
                    <Button x:Name="MyBidsButton" Content="Мои отклики" Template="{StaticResource myTemplate}" Width="140" Margin="0,0,10,0" Click="MyBidsButton_Click"/>
                    <Button x:Name="OrderBidsButton" Background="#10b364" Content="Отклики на мои заказы" Template="{StaticResource myTemplate}" Width="215" Click="OrderBidsButton_Click"/>
                </WrapPanel>

                <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,5,10,10" VerticalAlignment="Center">
                    <TextBlock x:Name="GuestText" Text="Гость" FontSize="14" VerticalAlignment="Center" 
           MaxWidth="450" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, ElementName=GuestText}" Opacity="0.7" Margin="0,0,10,0"/>
                    <Button x:Name="EnterButton" Content="Войти" Template="{StaticResource myTemplate}" Width="90" Height="35" Click="ButtonVoiti_Click" Margin="0,0,10,0"/>
                    <Button x:Name="ExitButton" Background="#f5b5d0" Content="Выйти" Template="{StaticResource myTemplate}" Width="90" Height="35" Click="ButtonExit_Click" Visibility="Collapsed"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Список откликов на мои заказы -->
        <ListBox x:Name="BidsList" Grid.Row="1" Margin="10" Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Margin="10" Background="White">
                        <StackPanel Margin="15">
                            <TextBlock Text="{Binding OrderTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding FreelancerName}" FontSize="14" Foreground="Blue" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Date, StringFormat='Отклик отправлен: dd.MM.yyyy HH:mm'}" FontSize="12" Foreground="Gray" Margin="0,0,0,10"/>
                            <Button Content="Написать в чат" Click="GoToChat_Click" Tag="{Binding}" Width="150"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Подвал -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="10" Margin="10" Background="#f8f8f8">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" 
                           Text="© 2026 Фриланс-биржа. Все права защищены. | Контакты: info@freelance.ru | +7 (999) 123-45-67"/>
                <WrapPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
                               TextDecorations="Underline" Text="Пользовательское соглашение" Margin="5"/>
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
                               TextDecorations="Underline" Text="Политика конфиденциальности" Margin="5"/>
                    <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#337ab7" 
                               TextDecorations="Underline" Text="Помощь и поддержка" Margin="5"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Page>